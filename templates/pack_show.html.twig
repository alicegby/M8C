{% extends 'base.html.twig' %}

{% block title %}{{ pack.name }} — Pack Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/pack.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos - Packs de Murder Parties</h1>

<section class="pack-show-hero animate-block">
    <div class="pack-show-header">
        <div class="pack-show-tag">PACK</div>
        <h2 class="pack-show-title">{{ pack.name }}</h2>

        {% if pack.price > 0 %}
            {% set totalOriginal = 0 %}
            {% for scenario in pack.getMurderParties() %}
                {% set totalOriginal = totalOriginal + scenario.price %}
            {% endfor %}

            {% if totalOriginal > pack.price %}
                <div class="pack-price-block">
                    <div class="pack-price-row">
                        <span class="price-original">{{ totalOriginal|number_format(2, ',', ' ') }} €</span>
                        <span class="price-final">{{ pack.price|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <span class="price-saving">🎉 Économisez {{ (totalOriginal - pack.price)|number_format(2, ',', ' ') }} €</span>
                </div>
            {% else %}
                <div class="pack-price-block">
                    <span class="price-final">{{ pack.price|number_format(2, ',', ' ') }} €</span>
                </div>
            {% endif %}
        {% else %}
            <div class="pack-price-block">
                <span class="price-final">Gratuit</span>
            </div>
        {% endif %}

        <p class="pack-show-description">{{ pack.description }}</p>

        <div class="pack-actions">
            {% if pack.price > 0 %}
                <button
                    class="btn-primary btn-add-cart"
                    data-id="{{ pack.id }}"
                    data-name="{{ pack.name }}"
                    data-price="{{ pack.price }}"
                    data-type="pack"
                    id="btn-add-cart"
                >
                    Ajouter au panier
                </button>
            {% else %}
                <a href="#" class="btn-jouer">Jouer</a>
            {% endif %}
        </div>
    </div>
</section>

{% if pack.getMurderParties()|length > 0 %}
<section class="pack-scenarios-section animate-block">
    <div class="container">
        <h3 class="pack-scenarios-title">
            <span class="scenarios-count">{{ pack.getMurderParties()|length }}</span>
            scénario{{ pack.getMurderParties()|length > 1 ? 's' : '' }} inclus
        </h3>
        <div class="mp-grid">
            {% for scenario in pack.getMurderParties() %}
                <div class="mp-card">
                    <div class="mp-card-header">
                        <h4>{{ scenario.title }}</h4>
                        <div class="mp-card-meta">
                            <span class="mp-meta-item">{{ scenario.duree }} min</span>
                            <span class="mp-meta-item">{{ scenario.nbPlayers }} joueurs</span>
                            {% if scenario.averageRating is not empty and scenario.averageRating != 0 %}
                                <span class="mp-meta-item">{{ scenario.averageRating }}/5</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="mp-card-body">
                        <p class="mp-synopsis">{{ scenario.synopsis }}</p>
                    </div>
                    <div class="mp-card-footer">
                        <a href="{{ path('scenario_show', {'slug': scenario.slug}) }}" class="btn-see">Voir la Murder Party →</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/scroll.js') }}"></script>
<script src="{{ asset('js/addtocart.js') }}"></script>
{% endblock %}
