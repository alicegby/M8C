{% extends 'base.html.twig' %}

{% block title %}Mon panier — Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/cart.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos - Jeu de Murder Party - Jeu de rôles - Jeu d'enquêtes</h1>
<h2>Mon panier</h2>

<section class="cart-section">
    <div class="container">
        {% if items is empty %}
            <div class="cart-empty">
                <p>Votre panier est vide.</p>
                <a href="{{ path('scenarios_list') }}" class="btn-primary">Découvrir les Murder Parties</a>
            </div>
        {% else %}
            <div class="cart-items">
                {% for item in items %}
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <span class="cart-item-type">
                                {% if item.type == 'pack' %}🩸 Pack{% else %}🩸 Scénario{% endif %}
                            </span>
                            <span class="cart-item-name">{{ item.name }}</span>
                        </div>
                        <div class="cart-item-actions">
                            <span class="cart-item-price">{{ item.price }} €</span>
                            <a href="{{ path('cart_remove', {'key': item.key}) }}" class="cart-remove">✕</a>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="cart-summary">
                <div class="cart-total">
                    <span>Total</span>
                    <span>{{ total|number_format(2, ',', ' ') }} €</span>
                </div>

                {% if app.user %}
                    <a href="{{ path('stripe_checkout_cart') }}" class="btn-primary cart-checkout">
                        Passer au paiement
                    </a>
                {% else %}
                    <p class="cart-login-notice">Vous devez être connecté pour poursuivre votre commande.</p>
                    <div class="auth-buttons">
                        <a href="{{ path('app_login', {'_target_path': path('cart_index')}) }}" class="btn-login">
                            Se connecter
                        </a>
                        <a href="{{ path('app_register') }}" class="btn-register">
                            Créer un compte
                        </a>
                    </div>
                {% endif %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}