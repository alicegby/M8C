{% extends 'base.html.twig' %}

{% block title %}Avis des joueurs — Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/avis.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos</h1>
<h2>Avis des joueurs</h2>


<section class="reviews-section animate-block">
    {% if reviews is empty %}
        <p>Aucun avis pour le moment.</p>
    {% else %}
        <ul class="reviews-list">
            {% for review in reviews %}
                <li class="review-item">
                    <p class="review-meta">
                        <strong>{{ review.authorPrenom }} {{ review.authorNom|slice(0,1) }}.</strong>
                        <span class="review-date">{{ review.createdAt|date('d/m/Y') }}</span>
                    </p>
                    <p class="review-content">{{ review.content }}</p>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</section>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/scroll.js') }}"></script>
{% endblock %}