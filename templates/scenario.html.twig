{% extends 'base.html.twig' %}

{% block title %}Murder Parties — Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/scenario.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos - Jeu de Murder Party - Jeu de rôles - Jeu d'enquêtes</h1>

<section class="scenarios-hero animate-block">
    <div class="container">
        <h2>Découvrez nos Murder Parties</h2>
        <p>
            Choisissez votre scénario et plongez dans l’enquête directement sur l'application. Chaque partie est unique ! 
        </p>
    </div>
</section>

<p class="intro animate-block">
    Toutes nos Murder Parties peuvent être commandées directement sur le site et se jouent exclusivement via l’application. Plongez dans l’enquête où que vous soyez ! 
</p>

<section class="scenario-devis animate-block">
    <div class="container">
        <h2>Murder Party personnalisé ?</h2>
        <p>
            Vous souhaitez organiser votre propre Murder Party sur mesure ? <br>
            N'hésitez pas à nous <a href="{{ path('contact') }}">contacter</a>.
        </p>
    </div>
</section>

<section class="scenarios-list animate-block">
    <div class="container">
        <div class="scenario-grid">
            {% for scenario in scenarios %}
                <div class="scenario-card">
                    <div class="scenario-content">
                        {% if scenario.coverImageUrl %}
                            <div class="scenario-image">
                                <img src="{{ asset('uploads/covers/' ~ scenario.coverImageUrl) }}" alt="{{ scenario.title }}">
                            </div>
                        {% endif %}
                        <h3>{{ scenario.title }}</h3>
                        <p class="scenario-meta">
                            ⏱︎ {{ scenario.duree }} minutes | {{ scenario.nbPlayers }} joueurs
                            {% if scenario.averageRating is not empty and scenario.averageRating != 0 %}
                                | {{ scenario.averageRating }}/5 ★
                            {% endif %}
                        </p>
                        <p class="scenario-price">
                            {% if scenario.price > 0 %}
                                {{ scenario.price|number_format(2, ',', ' ') }} €
                                <br>
                                <span class="price-per-player">
                                    Seulement {{ (scenario.price / scenario.nbPlayers)|number_format(2, ',', ' ') }} € / joueur
                                </span>
                            {% else %}
                                Gratuit
                            {% endif %}
                        </p>
                        <p class="scenario-synopsis">{{ scenario.synopsis }}</p>

                        <div class="scenario-buttons">
                            <a href="{{ path('scenario_show', {'slug': scenario.slug}) }}" class="btn-primary">Voir la Murder Party</a>
                            {% if scenario.price > 0 %}
                               <button
                                    class="btn-primary btn-add-cart"
                                    data-slug="{{ scenario.slug }}"
                                    data-name="{{ scenario.title }}"
                                    data-price="{{ scenario.price }}"
                                    id="btn-add-cart"
                                >
                                    Ajouter au panier
                                </button>
                            {% else %}
                                <a href="#" class="btn-cart">Jouer</a>
                            {% endif %}
                        </div>

                    </div>
                </div>
            {% else %}
                <p>Aucun scénario publié pour le moment.</p>
            {% endfor %}
        </div>
    </div>
</section>

<a href="{{ path('packs_list') }}" class="btn-primary btn-packs">Découvrez les Murder Parties en packs</a>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/scroll.js') }}"></script>
    <script src="{{ asset('js/addtocart.js') }}"></script>
{% endblock %}