{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe — Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/login.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos - Jeu de Murder Party - Jeu de rôles - Jeu d'enquêtes</h1>
<h2>Réinitialisez votre mot de passe</h2>

<div class="auth-container">
    <div class="auth-box auth-box--wide">

        <div class="auth-logo">
            <img src="{{ asset('images/logo.JPG') }}" alt="Meurtre à Huis Clos">
        </div>

        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error">{{ message }}</div>
        {% endfor %}

        <form method="post" class="auth-form">

            <div class="form-group">
                <label for="password">Nouveau mot de passe</label>
                <div class="input-password">
                    <input type="password" id="password" name="password" placeholder="Votre nouveau mot de passe" required>
                    <button type="button" class="toggle-password" aria-label="Afficher / Masquer le mot de passe">
                        <svg class="eye eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M12 5C5 5 1 12 1 12s4 7 11 7 11-7 11-7-4-7-11-7zm0 12a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/>
                            <circle cx="12" cy="12" r="2.5"/>
                        </svg>
                        <svg class="eye eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M2 2l20 20M12 5c-7 0-11 7-11 7s4 7 11 7c1.75 0 3.38-.42 4.87-1.16M12 19c7 0 11-7 11-7s-4-7-11-7c-1.75 0-3.38.42-4.87 1.16"/>
                        </svg>
                    </button>
                </div>
                <div class="password-strength" id="password-strength"></div>
            </div>

            <div class="form-group">
                <label for="password_confirm">Confirmez le mot de passe</label>
                <div class="input-password">
                    <input type="password" id="password_confirm" name="password_confirm" placeholder="Confirmez votre mot de passe" required>
                    <button type="button" class="toggle-password" aria-label="Afficher / Masquer le mot de passe">
                        <svg class="eye eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M12 5C5 5 1 12 1 12s4 7 11 7 11-7 11-7-4-7-11-7zm0 12a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/>
                            <circle cx="12" cy="12" r="2.5"/>
                        </svg>
                        <svg class="eye eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M2 2l20 20M12 5c-7 0-11 7-11 7s4 7 11 7c1.75 0 3.38-.42 4.87-1.16M12 19c7 0 11-7 11-7s-4-7-11-7c-1.75 0-3.38.42-4.87 1.16"/>
                        </svg>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-auth">Réinitialiser le mot de passe</button>
        </form>

        <div class="auth-links">
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/auth.js') }}"></script>
{% endblock %}