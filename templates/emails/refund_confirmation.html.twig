<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Votre remboursement a été effectué</title>
</head>
<body style="margin:0; padding:20px; background-color:#080808; font-family: Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color:#0E0E0E; border-radius:12px; overflow:hidden;">

                    <!-- Logo -->
                    <tr>
                        <td align="center" style="padding:30px 30px 20px 30px;">
                            <img src="{{ absolute_url(asset('images/logo.JPG')) }}" alt="Meurtre à Huis Clos" width="120" style="display:block; margin:0 auto;">
                        </td>
                    </tr>

                    <!-- Bande rouge -->
                    <tr>
                        <td style="background-color:#541826; height:3px;"></td>
                    </tr>

                    <!-- Contenu -->
                    <tr>
                        <td style="padding:35px 30px; text-align:center;">
                            <h2 style="color:#F5F5F5; font-size:1.6rem; margin:0 0 20px 0;">Votre remboursement a été traité</h2>
                            <p style="color:#CCCCCC; font-size:1rem; line-height:1.7; margin:0 0 25px 0;">
                                Bonjour {{ user.prenom }},<br><br>
                                Votre remboursement de <strong style="color:#F5F5F5;">{{ purchase.amountPaid }} €</strong> pour
                                <strong style="color:#F5F5F5;">
                                    {% if purchase.murderParty %}
                                        {{ purchase.murderParty.title }}
                                    {% elseif purchase.pack %}
                                        {{ purchase.pack.name }}
                                    {% endif %}
                                </strong>
                                a bien été effectué.<br><br>
                                Le montant sera crédité sur votre moyen de paiement sous <strong style="color:#F5F5F5;">5 à 10 jours ouvrés</strong>.
                            </p>

                            <p style="color:#888; font-size:0.85rem; line-height:1.5; margin:0;">
                                Une question ? Contactez-nous à <a href="mailto:contact@meurtrehuisclos.fr" style="color:#9D2137; text-decoration:none;">contact@meurtrehuisclos.fr</a>
                            </p>
                        </td>
                    </tr>

                    {% include 'emails/email_footer.html.twig' %}

                </table>
            </td>
        </tr>
    </table>
</body>
</html>