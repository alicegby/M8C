<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Confirmez votre inscription</title>
</head>
<body style="font-family: 'Arimo', serif; background-color: #000000; padding: 20px; margin: 0;">

    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center">
                <table width="600" cellpadding="20" cellspacing="0" style="background-color: #0E0E0E; border-radius: 12px;">

                    <!-- Logo -->
                    <tr>
                        <td align="center">
                            <img src="{{ absolute_url(asset('images/logo.JPG')) }}" alt="Meurtre à Huis Clos" width="140" style="display:block; margin-bottom: 20px;">
                        </td>
                    </tr>

                    <!-- Contenu -->
                    <tr>
                        <td>
                            <h2 style="color: #F5F5F5; font-family: 'Anton', serif; font-size: 1.8rem; margin-bottom: 15px;">Bienvenue {{ user.prenom }} !</h2>
                            <p style="color: #F5F5F5; font-size: 1rem; line-height: 1.5; margin-bottom: 15px;">
                                Merci de vous être inscrit sur <strong>Meurtre à Huis Clos</strong>.<br>
                                Pour activer votre compte, cliquez sur le bouton ci-dessous :
                            </p>

                            <p style="color: #F5F5F5; font-size: 1rem; margin-bottom: 20px;">
                                <a href="{{ verificationUrl }}" style="background-color: #541826; color: #F5F5F5; padding: 12px 25px; border-radius: 8px; font-weight: bold; text-decoration: none; font-size: 1.1rem;">Confirmer mon adresse email</a>
                            </p>

                            <p style="color: #F5F5F5; font-size: 1rem; line-height: 1.5; margin-bottom: 30px;">
                               Si vous n'avez pas créé de compte, ignorez cet email.
                            </p>
                        </td>
                    </tr>

                    <!-- Lien de téléchargement -->
                    <tr>
                        <td>
                            <h3 style="color: #F5F5F5; font-family: 'Anton', serif; font-size: 1.4rem; margin-bottom: 15px;">Téléchargez le jeu</h3>
                            <p style="color: #F5F5F5; font-size: 1rem; margin-bottom: 20px;">
                                Profitez de l'expérience Meurtre à Huis Clos sur tous vos appareils :
                            </p>

                            <table cellpadding="0" cellspacing="10" style="width: 100%; text-align: center;">
                                <tr>
                                    <td>
                                        <a href="#" style="background-color: #000000; color: #F5F5F5; padding: 12px 20px; border-radius: 8px; font-weight: bold; text-decoration: none; display: inline-block; font-family: 'Arimo', serif;">Android</a>
                                    </td>
                                    <td>
                                        <a href="#" style="background-color: #000000; color: #F5F5F5; padding: 12px 20px; border-radius: 8px; font-weight: bold; text-decoration: none; display: inline-block; font-family: 'Arimo', serif;">iOS</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Lien direct -->
                    <tr>
                        <td>
                            <p style="color: #F5F5F5; font-size: 0.9rem; margin-top: 30px;">Ce lien est valable une seule fois. Si vous avez des problèmes, copiez-collez ce lien dans votre navigateur :</p>
                            <p style="word-break: break-all; color: #541826;">{{ verificationUrl }}</p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>
</html>