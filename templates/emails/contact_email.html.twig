<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouveau message de contact</title>
</head>
<body style="margin:0; padding:20px; background-color:#080808; font-family: Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color:#0E0E0E; border-radius:12px; overflow:hidden;">

                    <!-- Header -->
                    <tr>
                        <td style="background-color:#541826; padding:20px 30px;">
                            <p style="margin:0; color:#F5F5F5; font-size:0.85rem; text-transform:uppercase; letter-spacing:2px;">Nouveau message de contact</p>
                        </td>
                    </tr>

                    <!-- Contenu -->
                    <tr>
                        <td style="padding:30px;">
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="padding:10px 0; border-bottom:1px solid #1f1f1f;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:4px;">Nom</span>
                                        <span style="color:#F5F5F5; font-size:1rem;">{{ data.nom|default('Non renseigné') }} {{ data.prenom|default('') }}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:10px 0; border-bottom:1px solid #1f1f1f;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:4px;">Email</span>
                                        <span style="color:#F5F5F5; font-size:1rem;">{{ data.email|default('Non renseigné') }}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:10px 0; border-bottom:1px solid #1f1f1f;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:4px;">Sujet</span>
                                        <span style="color:#F5F5F5; font-size:1rem;">{{ data.sujet|default('Non renseigné') }}</span>
                                    </td>
                                </tr>
                                {% if data.sousMenu is defined and data.sousMenu %}
                                <tr>
                                    <td style="padding:10px 0; border-bottom:1px solid #1f1f1f;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:4px;">Type d'événement</span>
                                        <span style="color:#F5F5F5; font-size:1rem;">{{ data.sousMenu }}</span>
                                    </td>
                                </tr>
                                {% endif %}
                                {% if data.nombrePersonnes is defined and data.nombrePersonnes %}
                                <tr>
                                    <td style="padding:10px 0; border-bottom:1px solid #1f1f1f;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:4px;">Nombre de participants</span>
                                        <span style="color:#F5F5F5; font-size:1rem;">{{ data.nombrePersonnes }}</span>
                                    </td>
                                </tr>
                                {% endif %}
                                {% if data.dateEvenement is defined and data.dateEvenement %}
                                <tr>
                                    <td style="padding:10px 0; border-bottom:1px solid #1f1f1f;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:4px;">Date souhaitée</span>
                                        <span style="color:#F5F5F5; font-size:1rem;">{{ data.dateEvenement }}</span>
                                    </td>
                                </tr>
                                {% endif %}
                                <tr>
                                    <td style="padding:20px 0 0 0;">
                                        <span style="color:#888; font-size:0.85rem; display:block; margin-bottom:10px;">Message</span>
                                        <div style="background-color:#1a1a1a; border-radius:8px; padding:15px; color:#F5F5F5; font-size:1rem; line-height:1.6; white-space:pre-line;">{{ data.message|default('Aucun message') }}</div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>
</html>
