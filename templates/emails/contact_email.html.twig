<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouveau message de contact</title>
    <style>
        body {
            background-color: #F5F5F5;
            color: #1C1C1C;
            margin: 0;
            padding: 20px;
        }
        .email-container {
            background-color: #FFFFFF;
            padding: 30px;
            border-radius: 12px;
            max-width: 700px;
            margin: auto;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        h2 {
            color: #541826;
            margin-bottom: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        th, td {
            text-align: left;
            padding: 10px 15px;
            border-bottom: 1px solid #EEEEEE;
        }
        th {
            background-color: #541826;
            color: #FFFFFF;
        }
        td {
            background-color: #F9F9F9;
        }
        .message-content {
            padding: 15px;
            background-color: #EFEFEF;
            border-radius: 8px;
            white-space: pre-line; /* affiche les sauts de ligne correctement */
        }
    </style>
</head>
<body>
    <div class="email-container">
        <h2>Nouveau message depuis la page Contact</h2>
        <table>
            <tr>
                <th>Nom</th>
                <td>{{ data.nom|default('Non renseigné') }}</td>
            </tr>
            <tr>
                <th>Prénom</th>
                <td>{{ data.prenom|default('Non renseigné') }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ data.email|default('Non renseigné') }}</td>
            </tr>
            <tr>
                <th>Sujet</th>
                <td>{{ data.sujet|default('Non renseigné') }}</td>
            </tr>
            {% if data.sousMenu is defined and data.sousMenu %}
            <tr>
                <th>Type d'événement</th>
                <td>{{ data.sousMenu }}</td>
            </tr>
            {% endif %}
            {% if data.nombrePersonnes is defined and data.nombrePersonnes %}
            <tr>
                <th>Nombre de participants</th>
                <td>{{ data.nombrePersonnes }}</td>
            </tr>
            {% endif %}
            {% if data.dateEvenement is defined and data.dateEvenement %}
            <tr>
                <th>Date souhaitée</th>
                <td>{{ data.dateEvenement }}</td>
            </tr>
            {% endif %}
        </table>

        <h3>Message :</h3>
        <div class="message-content">
            {{ data.message|default('Aucun message') }}
        </div>
    </div>
</body>
</html>