<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Joyeux anniversaire !</title>
</head>
<body style="margin:0; padding:20px; background-color:#080808; font-family: Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color:#0E0E0E; border-radius:12px; overflow:hidden;">

                    <!-- Logo -->
                    <tr>
                        <td align="center" style="padding:30px 30px 20px 30px;">
                            <img src="{{ absolute_url(asset('images/logo.JPG')) }}" alt="Meurtre à Huis Clos" width="120" style="display:block; margin:0 auto;">
                        </td>
                    </tr>

                    <!-- Bande rouge -->
                    <tr>
                        <td style="background-color:#541826; height:3px;"></td>
                    </tr>

                    <!-- Contenu -->
                    <tr>
                        <td style="padding:35px 30px; text-align:center;">
                            <h2 style="color:#F5F5F5; font-size:1.6rem; margin:0 0 10px 0;">🎂 Joyeux anniversaire {{ user.prenom }} !</h2>
                            <p style="color:#CCCCCC; font-size:1rem; line-height:1.7; margin:0 0 25px 0;">
                                Toute l'équipe <strong style="color:#F5F5F5;">Meurtre à Huis Clos</strong> vous souhaite un très bel anniversaire.<br>
                                Pour fêter ça, voici un cadeau exclusif valable 30 jours :
                            </p>

                            <!-- Code promo -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 25px 0;">
                                <tr>
                                    <td align="center">
                                        <table cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td style="background-color:#1a1a1a; border:2px dashed #541826; border-radius:8px; padding:20px 30px; text-align:center;">
                                                    <p style="color:#888; font-size:0.8rem; margin:0 0 8px 0; text-transform:uppercase; letter-spacing:2px;">Votre cadeau d'anniversaire</p>
                                                    <p style="color:#F5F5F5; font-size:1.8rem; font-weight:bold; margin:0 0 8px 0; letter-spacing:3px;">{{ promoCode }}</p>
                                                    <p style="color:#888; font-size:0.8rem; margin:0;">10% de réduction — 1 utilisation — 30 jours</p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Bouton CTA -->
                            <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 25px 0;">
                                <tr>
                                    <td align="center">
                                        <table cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td style="background-color:#541826; border-radius:8px;">
                                                    <a href="{{ app_url }}" style="display:inline-block; padding:14px 30px; color:#F5F5F5; text-decoration:none; font-weight:bold; font-size:1rem;">
                                                        Utiliser mon code
                                                    </a>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <p style="color:#888; font-size:0.85rem; line-height:1.5; margin:0;">
                                Ce code est valable uniquement sur <a href="{{ app_url }}" style="color:#9D2137; text-decoration:none;">meurtrehuisclos.fr</a> et ne peut être utilisé qu'une seule fois.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    {% include 'emails/email_footer.html.twig' with { unsubscribeToken: unsubscribeToken } %}

                </table>
            </td>
        </tr>
    </table>
</body>
</html>
