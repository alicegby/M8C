<h3>
    Liste des clients
    <button id="filter-toggle" class="filter-btn">
        <img src="{{ asset('icones/filter_white.png') }}" alt="Filter">
    </button>
</h3> 

<div id="filter-menu" class="filter-menu hidden">
    <label>
        Mot-clé :
        <input type="text" id="user-search" placeholder="Prénom, nom ou email...">
    </label>
    <label>
        Newsletter :
        <select id="newsletter-filter">
            <option value="">Tous</option>
            <option value="1">Abonnés</option>
            <option value="0">Non abonnés</option>
        </select>
    </label>
</div>

<p class="user-count">
    Total : <span id="user-count">{{ users|length }}</span> client(s)
</p>


<table id="user-table">
    <thead>
        <tr>
            <th>Prénom</th>
            <th>Nom</th>
            <th>Email</th>
            <th>Newsletter</th>
            <th>Rôle</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="user-table-body">
        {% for user in users %}
            <tr>
                <td>{{ user.prenom }}</td>
                <td>{{ user.nom }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.newsletter ? 'Oui' : 'Non' }}</td>
                <td>{{ user.role }}</td>
                <td>
                    <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-show ajax-link-show">
                        Voir
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun client trouvé.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>