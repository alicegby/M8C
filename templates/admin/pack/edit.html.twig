{% extends 'base.html.twig' %}

{% block title %}Modifier : {{ pack.name }} — Admin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin/pack.css') }}">
{% endblock %}

{% block body %}

<h1>Meurtre à Huis Clos - Jeu de Murder Party - Jeu de rôles - Jeu d'enquêtes</h1>
<h2>Modifier le pack : {{ pack.name }}</h2>

{{ form_start(form, {'attr': {'id': 'pack-form'}}) }}

<div class="mp-forms">
    <div class="mp-main-form">
        <h3>Informations du Pack</h3>

        {{ form_row(form.name) }}
        {{ form_row(form.description) }}
        {{ form_row(form.price) }}

        <div class="form-group--checkbox">
            {{ form_widget(form.isActive) }}
            {{ form_label(form.isActive) }}
        </div>

        <h3>Murder Parties incluses</h3>
        <div class="pack-mp-list">
            {% for mp in form.murderParties %}
                <div class="form-check">
                    {{ form_widget(mp) }}
                    {{ form_label(mp) }}
                </div>
            {% else %}
                <p class="empty-message">Aucune Murder Party disponible.</p>
            {% endfor %}
        </div>
    </div>

    <div class="mp-submit">
        <button type="submit" class="btn btn-add btn-submit">Sauvegarder</button>
    </div>
</div>

{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/admin.js') }}"></script>
{% endblock %}