{% extends 'base.html.twig' %}

{% block title %}Modifier une Murder Party{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin/mp.css') }}">
{% endblock %}

{% block body %}

<h1>Meurtre à Huis Clos - Jeu de Murder Party - Jeu de rôles - Jeu d'enquêtes</h1>
<h2>Modifier la Murder Party : {{ mp. title }}</h2>

{{ form_start(form, {'attr': {'id': 'murder-party-form'}}) }}

<div class="mp-forms">

    <div class="mp-main-form">
        <h3>Murder Party</h3>

        {{ form_row(form.title) }}
        {{ form_row(form.slug) }}
        {{ form_row(form.nbPlayers) }}
        {{ form_row(form.duree) }}
        {{ form_row(form.synopsis) }}
        {{ form_row(form.scenario) }}
        {{ form_row(form.epilogue) }}
        {{ form_row(form.coverImageUrl) }}
        {{ form_row(form.price) }}

        <div class="form-group--checkbox">
            {{ form_widget(form.isFree) }}
            {{ form_label(form.isFree) }}
        </div>

        <div class="form-group--checkbox">
            {{ form_widget(form.isPublished) }}
            {{ form_label(form.isPublished) }}
        </div>
    </div>

    <div class="mp-character-form">
        <h3>Personnages</h3>

        <div id="characters-list"
             data-prototype="{{ form_widget(form.characters.vars.prototype)|e('html_attr') }}">

            {% if form.characters|length == 0 %}
                <p class="empty-message">Aucun personnage ajouté.</p>
            {% else %}
                {% for characterForm in form.characters %}
                    <div class="mp-character-item">
                        <button type="button" class="btn-remove">Supprimer</button>
                        <div class="character-header">
                            <h4>Personnage {{ loop.index }}</h4>
                            <button type="button" class="btn-toggle-character">▼</button>
                        </div>
                        <div class="character-body hidden">
                            {{ form_row(characterForm.prenom) }}
                            {{ form_row(characterForm.nom) }}
                            {{ form_row(characterForm.age) }}
                            {{ form_row(characterForm.job) }}
                            {{ form_row(characterForm.histoire) }}
                            {{ form_row(characterForm.mobile) }}
                            {{ form_row(characterForm.alibi) }}
                            {{ form_row(characterForm.extraInfo) }}
                            <div class="form-group--checkbox">
                                {{ form_widget(characterForm.isGuilty) }}
                                {{ form_label(characterForm.isGuilty) }}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}

        </div>

        <button type="button" id="add-character-btn" class="btn btn-add">
            Ajouter un personnage
        </button>
    </div>

    <div class="mp-clue-form">
        <h3>Indices</h3>

        <div id="clues-list"
             data-prototype="{{ form_widget(form.clues.vars.prototype)|e('html_attr') }}">

            {% if form.clues|length == 0 %}
                <p class="empty-message">Aucun indice ajouté.</p>
            {% else %}
                {% for clueForm in form.clues %}
                    <div class="mp-clue-item">
                        <button type="button" class="btn-remove">Supprimer</button>
                        <div class="clue-header">
                            <h4>Indice {{ loop.index }}</h4>
                            <button type="button" class="btn-toggle-clue">▼</button>
                        </div>
                        <div class="clue-body hidden">
                            {{ form_row(clueForm.content) }}
                            {{ form_row(clueForm.triggerMinutes) }}
                            {{ form_row(clueForm.character) }}
                            <div class="form-group--checkbox">
                                {{ form_widget(clueForm.isPublic) }}
                                {{ form_label(clueForm.isPublic) }}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}

        </div>

        <button type="button" id="add-clue-btn" class="btn btn-add">
            Ajouter un indice
        </button>
    </div>

    <div class="mp-submit">
        <button type="submit" class="btn btn-add btn-submit">
            Sauvegarder
        </button>
    </div>

</div>

{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/admin.js') }}"></script>
{% endblock %}