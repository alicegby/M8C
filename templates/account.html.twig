{% extends 'base.html.twig' %}

{% block title %}Mon compte — Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/account.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos</h1>
<h2>Bonjour {{ user.prenom }}</h2>
 
<div class="account-container">

    <div class="account-top animate-block">
        <div class="account-header">
            <div class="account-avatar">
                {% if user.avatarUrl %}
                    <img src="{{ user.avatarUrl }}" alt="Avatar">
                {% else %}
                    <div class="account-avatar__placeholder">
                        {{ user.prenom|slice(0,1)|upper }}{{ user.nom|slice(0,1)|upper }}
                    </div>
                {% endif %}
            </div>
            <div class="account-header__info">
                <h2>{{ user.prenom }} {{ user.nom }}</h2>
                <p class="account-email">{{ user.email }}</p>
                <p class="account-since">Membre depuis {{ user.createdAt|date('d/m/Y') }}</p>
            </div>
        </div>

        <div class="account-card">
            <h3>Mes informations 
                <a href="{{ path('account_edit') }}" class="btn-edit">Modifier</a>
            </h3>
            <ul class="account-info-list">
                <li><span>Prénom</span><strong>{{ user.prenom }}</strong></li>
                <li><span>Nom</span><strong>{{ user.nom }}</strong></li>
                <li><span>Email</span><strong>{{ user.email }}</strong></li>
                {% if user.dob %}
                <li><span>Date de naissance</span><strong>{{ user.dob|date('d/m/Y') }}</strong></li>
                {% endif %}
                {% if user.pseudo %}
                <li><span>Pseudo</span><strong>{{ user.pseudo }}</strong></li>
                {% endif %}
            </ul>
        </div>
    </div>

    <div class="account-preferences account-card animate-block">
        <h3>Préférences</h3>
        <ul class="account-info-list">
            <li>
                <span>Newsletter</span>
                {% if isSubscribed %}
                    <strong>Activée</strong>
                    <form action="{{ path('account_toggle_newsletter') }}" method="post" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('newsletter_toggle') }}">
                        <button type="submit" class="btn-primary" style="margin-left:10px; padding:5px 15px; font-size:0.85rem;">Se désinscrire</button>
                    </form>
                {% else %}
                    <form action="{{ path('account_toggle_newsletter') }}" method="post" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('newsletter_toggle') }}">
                        <button type="submit" class="btn-primary" style="padding:5px 15px; font-size:0.85rem;">S'inscrire</button>
                    </form>
                {% endif %}
            </li>
        </ul>
        <a href="{{ path('avis_new') }}" class="btn-primary">Laisser un avis sur Meurtre à Huis Clos</a>
    </div>

    <div class="account-grid animate-block">

        <div class="account-card">
            <h3>Murder Parties jouées</h3>
            {% if playedMPs is empty %}
                <p class="account-empty">Vous n'avez encore participé à aucune partie.</p>
            {% else %}
                <ul class="account-purchases-list">
                    {% for played in playedMPs %}
                        <li>
                            <strong>{{ played.gameSession.murderParty.title }}</strong>
                            <span>{{ played.gameSession.createdAt|date('d/m/Y') }}</span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>

        <div class="account-card">
            <h3>Mes Murder Parties achetées</h3>
            {% if purchases is empty %}
                <p class="account-empty">Aucune Murder Party achetée pour le moment.</p>
            {% else %}
                <ul class="account-purchases-list">
                    {% for p in purchases %}
                        <li>
                            <strong>
                                {% if p.murderParty %}
                                    {{ p.murderParty.title }}
                                {% elseif p.pack %}
                                    {{ p.pack.name }}
                                {% else %}
                                    Achat inconnu
                                {% endif %}
                            </strong>
                            <div class="account-purchase-meta">
                                <span>{{ p.purchasedAt|date('d/m/Y') }}</span>
                                {% if p.status == 'refunded' %}
                                    <span class="badge-refunded">Remboursé</span> 
                                {% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
        </div>

    </div>

    {# Footer #}
    <div class="account-footer animate-block">
        <div class="app-access">
            <h4>Accéder à l'application</h4>
            <div class="app-buttons">
                <a href="https://apps.apple.com/fr/app/meurtre-%C3%A0-huis-clos/id6760702842" target="_blank" class="btn-app">
                    <img src="{{ asset('icones/apple_white.png') }}" alt="Apple">
                </a>
                <a href="#" class="btn-app">
                    <img src="{{ asset('icones/android_white.png') }}" alt="Android">
                </a>
            </div>
        </div>

        <a href="{{ path('app_logout') }}" class="btn-logout">Se déconnecter</a>

        <form action="{{ path('account_delete') }}" method="post" onsubmit="return confirm('Êtes-vous sûr(e) de vouloir supprimer votre compte ? Cette action est irréversible.');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
            <button type="submit" class="btn-suppr">Supprimer mon compte</button>
        </form>
    </div>

</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/scroll.js') }}"></script>
{% endblock %}