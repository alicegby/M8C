{# templates/security/forgot_password.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — Meurtre à Huis Clos{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/login.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos - Jeu de Murder Party - Jeu de rôles - Jeu d'enquêtes</h1>
<h2>Réinitialisez votre mot de passe</h2>

<div class="auth-container animate-block">
    <div class="auth-box">

        <div class="auth-logo">
            <img src="{{ asset('images/logo.JPG') }}" alt="Meurtre à Huis Clos">
        </div>

        <p class="auth-subtitle">
            Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
        </p>

        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error">{{ message }}</div>
        {% endfor %}

        <form method="post" action="{{ path('app_forgot_password_request') }}" class="auth-form">
            <div class="form-group">
                <label for="email">Adresse email</label>
                <input type="email" id="email" name="email"
                       placeholder="votre@email.com"
                       required>
            </div>

            <button type="submit" class="btn-auth">Envoyer le lien de réinitialisation</button>
        </form>

        <div class="auth-links">
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/scroll.js') }}"></script>
{% endblock %}