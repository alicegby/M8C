{% extends 'base.html.twig' %}

{% block title %}Accueil — Meurtre à Huis Clos{% endblock %}
{% block meta_description %}Découvrez Meurtre à Huis Clos, le jeu de Murder Party immersif. Vivez des enquêtes captivantes entre amis, en famille ou entre collègues.{% endblock %}
{% block og_title %}Meurtre à Huis Clos - Murder Party immersive{% endblock %}
{% block og_url %}https://meurtrehuisclos.fr/{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/home.css') }}">
{% endblock %}

{% block body %}
<h1>Meurtre à Huis Clos</h1>

<section class="hero animate-block">
    <div class="hero-content">
        <h2>Entrez dans l'enquête</h2>
        <p>
            Chaque détail compte. Chaque regard cache un secret. <br>
            Bienvenue dans votre jeu de Murder Party.
        </p>
        <a href="{{ path('scenarios_list') }}" class="btn-primary">Découvrir les Murder Parties</a>
    </div>
</section>

<section class="concept animate-block">
    <div class="container">
        <h2>Un jeu immersif d'enquête</h2>
        <p>
            Incarnez un personnage. <br> 
            Enquêtez sur les alibis et les mobiles des suspects. <br>
            Démasquez le coupable avant qu’il ne soit trop tard.
        </p>
    </div>
    <div class="scenarios animate-block">
        {% for scenario in topScenarios %}
        <div class="scenario">
            <h3>{{ scenario.title }}</h3>
            <p class="scenario-meta">⏱︎ {{ scenario.duree }} minutes | {{ scenario.nbPlayers }} joueurs | {% if scenario.averageRating > 0 %} {{ scenario.averageRating }}/5 ★{% endif %}</p>
            <p>{{ scenario.synopsis }}</p>
        </div>
        {% endfor %}
        <div class="scenario-btn">
            <a href="{{ path('scenarios_list') }}">Voir toutes les Murder Parties</a>
        </div>
        <div class="mp-surmesure">
            <p>
                Vous souhaitez organiser votre propre Murder Party sur mesure ? <br>
                N'hésitez pas à nous <a href="{{ path('contact') }}">contacter</a>.
            </p>
        </div>
    </div>
</section>

<section class="telechargement animate-block">
    <div class="telechargement-container">
        <h2>Télécharger Meurtre à Huis Clos</h2>
        <p>
            Téléchargez le jeu sur votre téléphone et commencez votre enquête. <br> Qui dans vos proches est le coupable ? 
        </p>
        <a href="https://apps.apple.com/fr/app/meurtre-%C3%A0-huis-clos/id6760702842" target="_blank">
            <img src="{{ asset('icones/apple_white.png') }}" alt="Téléchargement Apple">
        </a>
        <!--<a href="#">
            <img src="{{ asset('icones/android_white.png') }}" alt="Téléchargement Android">
        </a>-->
    </div>
</section>

<section class="avis animate-block">
    <div class="avis-container">
        <h2>Les joueurs ont adoré</h2>
        <p>Faites-leur confiance et lancez-vous dans votre enquête !</p>
        <div class="voir-avis">
            <a href="{{ path('avis') }}">
                Voir tous les avis
            </a>
        </div>
    </div>
</section>

<section class="newsletter animate-block">
    <div class="newsletter-container">
        <h2>Inscrivez-vous à notre newsletter</h2>
        <p>
            Recevez les informations des dernières Murder Parties, promos et contenus exclusifs directement dans votre boîte mail, et recevez 10% de remise.
        </p>

        <form action="{{ path('newsletter_subscribe') }}" method="POST" class="newsletter-form">
            <input type="email" name="email" placeholder="Votre email" required>
            <button type="submit">S’inscrire</button>
        </form>

        {% if newsletter_success is defined %}
            <p class="newsletter-success">{{ newsletter_success }}</p>
        {% endif %}
    </div>
</section>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/scroll.js') }}"></script>
{% endblock %}
