{% extends 'base.html.twig' %}

{% block page_title %}{{ scenario.title }} — Murder Party{% endblock %}
{% block meta_description %}{{ scenario.synopsis|slice(0, 155)|striptags }}{% endblock %}
{% block og_title %}{{ scenario.title }} — Meurtre à Huis Clos{% endblock %}
{% block og_description %}{{ scenario.synopsis|slice(0, 200)|striptags }}{% endblock %}
{% block og_type %}product{% endblock %}
{% block canonical %}https://meurtrehuisclos.fr/scenarios/{{ scenario.slug }}{% endblock %}
{% if scenario.coverImageUrl %}
    {% block og_image %}{{ scenario.coverImageUrl }}{% endblock %}
{% endif %}

{% block schema_jsonld %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ scenario.title|json_encode|raw }},
    "description": {{ scenario.synopsis|striptags|json_encode|raw }},
    "url": "https://meurtrehuisclos.fr/scenarios/{{ scenario.slug }}",
    {% if scenario.coverImageUrl %}
    "image": {{ scenario.coverImageUrl|json_encode|raw }},
    {% endif %}
    "brand": {
        "@type": "Brand",
        "name": "Meurtre à Huis Clos"
    },
    "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "price": "{{ scenario.price }}",
        "availability": "https://schema.org/InStock",
        "url": "https://meurtrehuisclos.fr/scenarios/{{ scenario.slug }}"
    }
    {% if scenario.ratingsCount > 0 %}
    ,
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "{{ scenario.averageRating }}",
        "reviewCount": "{{ scenario.ratingsCount }}",
        "bestRating": "5",
        "worstRating": "1"
    }
    {% endif %}
}
</script>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/scenarioshow.css') }}">
{% endblock %}

{% block body %}

<h1>Meurtre à Huis Clos</h1>

<section class="scenario-show-page">

    <h2 class="scenario-title">{{ scenario.title }}</h2>

    <div class="scenario-layout">

        {# COLONNE GAUCHE #}
        <div class="scenario-left">

            <p class="scenario-meta">
                ⏱︎ {{ scenario.duree }} min | {{ scenario.nbPlayers }} joueurs
                {% if scenario.averageRating %}
                    | {{ scenario.averageRating }}/5 ★
                {% endif %}
            </p>

            <p class="scenario-synopsis">
                {{ scenario.synopsis }}
            </p>

            <p class="scenario-secret">
                Le scénario vous sera dévoilé complètement au lancement de la partie.
            </p>

            <a href="{{ path('rules') }}" class="btn-rules">
                Voir les règles
            </a>

        </div>

        {# COLONNE DROITE #}
        <div class="scenario-right">

            <p class="tarif">
                {% if scenario.isFree %}
                    Gratuit
                {% else %}
                    {{ scenario.price|number_format(2, ',', ' ') }} €
                    <span class="price-per-player">
                        {% if scenario.nbPlayers > 0 %}
                            Seulement {{ (scenario.price / scenario.nbPlayers)|number_format(2, ',', ' ') }} € / joueur
                        {% endif %}
                    </span>
                {% endif %}
            </p>

            <div class="scenario-btns">

                {% if scenario.isFree or isPurchased %}
                    <a href="https://apps.apple.com/fr/app/meurtre-%C3%A0-huis-clos/id6760702842" target="_blank" class="btn-jouer">Jouer</a>
                {% else %}
                    <button
                        class="btn-primary btn-add-cart"
                        data-slug="{{ scenario.slug }}"
                        data-name="{{ scenario.title }}"
                        data-price="{{ scenario.price }}"
                        id="btn-add-cart">
                        Ajouter au panier
                    </button>
                {% endif %}

            </div>

            <a href="{{ path('packs_list') }}" class="btn-packs">
                Découvrez les Murder Parties en packs
            </a>

        </div>

    </div>

    {# SECTION TELECHARGEMENT #}
    <div class="download-section">

        <h3>Téléchargez le jeu</h3>

        <div class="download-buttons">
            <a href="https://apps.apple.com/fr/app/meurtre-%C3%A0-huis-clos/id6760702842" target="_blank">
                <img src="{{ asset('icones/apple_red.png') }}" alt="Télécharger sur l'App Store">
            </a>
            <a href="#">
                <img src="{{ asset('icones/android_red.png') }}" alt="Télécharger sur Android">
            </a>
        </div>

    </div>

</section>

{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/scroll.js') }}"></script>
<script src="{{ asset('js/addtocart.js') }}"></script>
{% endblock %}
